{
  "database": {
    "rules": "firebase/database.rules.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "emulators": {
    "functions": { "port": 5001 },
    "database":  { "port": 9000 },
    "ui":        { "enabled": true }
  }
}
