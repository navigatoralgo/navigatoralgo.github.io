{
  "_comment": "Firebase Realtime Database security rules for Navigator Algo. Copy the 'rules' object into Firebase console → Realtime Database → Rules. DO NOT ship without these — without them, anyone with the DB URL can read every provider's data and mint fake licenses.",

  "rules": {
    ".read":  false,
    ".write": false,

    "admins": {
      "_comment": "Admin allowlist. Set /admins/{uid} = true in Firebase console for each admin. Admins can mint new provider IDs + list all providers. Regular users can only check their own admin status (used to conditionally show the Admin nav link).",
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": false,
        ".validate": "newData.isBoolean()"
      }
    },

    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "provider_id":  { ".validate": "newData.isString() && newData.val().length <= 32" },
        "email":        { ".validate": "newData.isString() && newData.val().length <= 256" },
        "display_name": { ".validate": "newData.isString() && newData.val().length <= 64" },
        "phone":        { ".validate": "newData.isString() && newData.val().length <= 32" },
        "country":      { ".validate": "newData.isString() && newData.val().length <= 64" },
        "notes":        { ".validate": "newData.isString() && newData.val().length <= 500" },
        "created_at":   { ".validate": "newData.isNumber()" },
        "last_seen_at": { ".validate": "newData.isNumber()" },
        "updated_at":   { ".validate": "newData.isNumber()" }
      }
    },

    "providers": {
      "_comment": "Admins can list all providers (for the admin mint page). Regular users fall through to per-$pid rules where they can only read their own claimed provider.",
      ".read":  "auth != null && root.child('admins').child(auth.uid).val() === true",

      "$pid": {
        ".read":  "auth != null && (data.child('owner_uid').val() === auth.uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && ( (data.exists() && data.child('owner_uid').val() === auth.uid) || (data.exists() && !data.child('owner_uid').exists()) || (!data.exists() && root.child('admins').child(auth.uid).val() === true) )",

        "owner_uid":   { ".validate": "newData.isString() || newData.val() == null" },
        "owner_email": { ".validate": "newData.isString() || newData.val() == null" },
        "claim_token": { ".validate": "newData.isString() || newData.val() == null" },
        "ea_key":      { ".validate": "newData.isString() && newData.val().length <= 64" },
        "ea_key_rotated_at": { ".validate": "newData.isNumber() || newData.val() == null" },
        "license":     { ".validate": "newData.isString()" },
        "display_name":{ ".validate": "newData.isString() && newData.val().length <= 64" },
        "created_at":  { ".validate": "newData.isNumber()" },
        "created_by_uid":{ ".validate": "newData.isString()" },
        "claimed_at":  { ".validate": "newData.isNumber() || newData.val() == null" },

        "sub_licenses": {
          "$code": {
            ".validate": "newData.hasChildren(['state'])",
            "state":       { ".validate": "newData.val() === 'unused' || newData.val() === 'active' || newData.val() === 'revoked' || newData.val() === 'expired'" },
            "bound_account":{ ".validate": "newData.isString() || newData.val() == null" },
            "bound_broker":{ ".validate": "newData.isString() || newData.val() == null" },
            "activated_at":{ ".validate": "newData.isNumber() || newData.val() == null" },
            "last_seen_at": { ".validate": "newData.isNumber() || newData.val() == null" },
            "expires_at":  { ".validate": "newData.isNumber() || newData.val() == null" }
          }
        },

        "receivers": {
          ".indexOn": ["activated_at"],
          "$acct": {
            "state":        { ".validate": "newData.val() === 'active' || newData.val() === 'inactive'" },
            "bound_broker": { ".validate": "newData.isString() || newData.val() == null" },
            "license_code": { ".validate": "newData.isString()" },
            "activated_at": { ".validate": "newData.isNumber()" },
            "last_seen_at": { ".validate": "newData.isNumber()" }
          }
        },

        "signals": {
          "_comment": "Receivers need to read signals; providers write them. Individual signal validation lives on the writer (Cloud Functions).",
          ".read":  "auth != null",
          ".indexOn": ["seq"]
        },

        "stats": {
          "_comment": "Aggregated counters for dashboard; written by Cloud Functions.",
          "total_signals":  { ".validate": "newData.isNumber()" },
          "active_copiers": { ".validate": "newData.isNumber()" },
          "last_signal_at": { ".validate": "newData.isNumber()" },
          "next_seq":       { ".validate": "newData.isNumber()" },
          "updated_at":     { ".validate": "newData.isNumber()" },
          "win_rate":       { ".validate": "newData.isNumber()" },
          "balance":        { ".validate": "newData.isNumber()" },
          "equity":         { ".validate": "newData.isNumber()" },
          "drawdown_pct":   { ".validate": "newData.isNumber()" }
        },

        "heartbeat": {
          ".validate": "newData.isNumber()"
        },

        "heartbeat_meta": {
          "ea_version": { ".validate": "newData.isString() && newData.val().length <= 32" },
          "mt5_build":  { ".validate": "newData.isNumber()" }
        }
      }
    },

    "licenses": {
      "_comment": "Individual license nodes. Receivers validate their key by reading /licenses/{code}. Write access restricted to admin/service account.",
      "$code": {
        ".read":  "auth != null || true",
        ".write": false,
        ".validate": "newData.hasChildren(['type','state'])"
      }
    },

    "public_providers": {
      "_comment": "Optional: per-provider public stats page at navigatoralgo.com/p/{provider_id}. Stores only non-sensitive fields (display_name, active_copiers count, total_signals). Populated by a Cloud Function scheduled job.",
      ".read":  true,
      "$pid": {
        ".write": false
      }
    }
  }
}
